# Postgres connection string (must point at a database with pgvector available)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/personal_assistant

# AI provider: claude | ollama | openai
AI_PROVIDER=ollama

# Claude (chat) - required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Cohere (embeddings) - required when AI_PROVIDER=claude
COHERE_API_KEY=

# OpenAI - required when AI_PROVIDER=openai
OPENAI_API_KEY=

# Ollama - used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=personal-assistant-files
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Server
PORT=3000

# Comma-separated list of allowed CORS origins (frontend URL)
CORS_ORIGIN=http://localhost:4200
