# Postgres connection string (must point at a database with pgvector available)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/personal_assistant

# AI provider: claude | ollama | openai
AI_PROVIDER=ollama

# Claude (chat) - required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Cohere (embeddings) - required when AI_PROVIDER=claude
COHERE_API_KEY=

# OpenAI - required when AI_PROVIDER=openai
OPENAI_API_KEY=

# Ollama - used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Tavily - web search for chat (https://tavily.com)
TAVILY_API_KEY=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=personal-assistant-files
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Email (export "email to self") - leave SMTP_HOST blank to disable
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=

# Server
PORT=3000

# Comma-separated list of allowed CORS origins (frontend URL)
CORS_ORIGIN=http://localhost:4200

# Default minimum relevance score (0-1) for GET /api/notes/search results
SEARCH_MIN_SCORE=0.5

# Max number of chat_messages rows retained; older messages are pruned after each insert
CHAT_HISTORY_LIMIT=50
