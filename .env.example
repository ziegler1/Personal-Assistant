# ---------------------------------------------------------------------------
# Zig's Personal Assistant - environment variables
# Copy this file to .env (root, for docker-compose) and adjust as needed.
# Each service also has its own .env.example with the same variables.
# ---------------------------------------------------------------------------

# --- Database -----------------------------------------------------------
# Local docker-compose Postgres (pgvector enabled image)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/personal_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=personal_assistant

# --- AI Provider ----------------------------------------------------------
# claude | ollama | openai
# - claude: chat via Anthropic Claude, embeddings via Cohere
# - ollama: chat + embeddings via local Ollama (no API keys needed)
# - openai: chat + embeddings via OpenAI
AI_PROVIDER=ollama

# Claude (chat) - required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Cohere (embeddings) - required when AI_PROVIDER=claude
COHERE_API_KEY=

# OpenAI - required when AI_PROVIDER=openai
OPENAI_API_KEY=

# Ollama - used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Web search ------------------------------------------------------------
# Tavily API key, used by chat to search the web (https://tavily.com).
# Required for "search:" prefix and auto web-search fallback in chat.
TAVILY_API_KEY=

# --- Cloudflare R2 (file storage) -----------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=personal-assistant-files
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Email (export "email to self") ----------------------------------------
# SMTP settings used to send generated exports to NOTIFY_EMAIL.
# Leave SMTP_HOST blank to disable the "email to self" export action.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=

# --- Authentication ---------------------------------------------------------
APP_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string

# --- Server -----------------------------------------------------------------
PORT=3000
